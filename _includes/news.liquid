<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and site.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.year_from %}
          {% assign filtered_news = "" | split: "" %}
          {% for item in news %}
            {% assign item_year = item.date | date: '%Y' | plus: 0 %}
            {% if item_year >= include.year_from %}
              {% assign filtered_news = filtered_news | push: item %}
            {% endif %}
          {% endfor %}
          {% assign news = filtered_news %}
        {% endif %}
        {% assign news_size = news | size %}
        {% if include.year_from %}
          {% assign news_limit = news_size %}
        {% elsif include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr style="padding: 0; line-height: 1.3">
            <th scope="row" style="width: 20%; padding: 1px 4px 1px 0; font-weight: normal; white-space: nowrap">{{ item.date | date: '%b %Y' }}</th>
            <td style="padding: 1px 0">
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
